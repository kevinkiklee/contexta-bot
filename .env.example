# ============================
# Contexta Monorepo — Environment Variables
# Copy to .env and fill in values.
# ============================

# --- Shared Infrastructure ---
DATABASE_URL=postgresql://contexta:contexta@localhost:5432/contexta_bot
REDIS_URL=redis://localhost:6379
DISABLE_DB_SSL=true

# --- Bot ---
# Each bot instance (dev/prod) runs as a separate process with its own token and client ID.
# For local dev, set these to whichever bot you're running.
DISCORD_TOKEN=               # Bot token (Developer Portal → Bot → Token)
BOT_CLIENT_ID=               # Application ID (Developer Portal → General Information)
DEV_GUILD_ID=                # Guild ID for instant slash-command registration (optional, dev only)
BOT_API_KEY=                 # Shared secret the bot uses to authenticate with the backend
BACKEND_URL=http://localhost:4000

# --- Backend ---
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CRON_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PORT=4000

# --- Dashboard ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=             # openssl rand -base64 32
AUTH_SECRET=                 # Same as NEXTAUTH_SECRET (NextAuth v5 compat)
DISCORD_CLIENT_ID=           # OAuth app client ID (for user login, NOT the bot)
DISCORD_CLIENT_SECRET=       # OAuth app client secret

# Bot selector — comma-separated Label:ApplicationId pairs.
# The dashboard uses this to let you switch between bot instances.
# Example: BOTS=Dev:1234567890123,Prod:9876543210987
BOTS=
