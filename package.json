{
  "name": "contexta",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:all": "./scripts/dev.sh && (pnpm run dev:backend & pnpm run dev:bot & pnpm run dev:dashboard & pnpm run dev:website & wait)",
    "dev:bot": "pnpm --filter @contexta/bot dev",
    "dev:backend": "pnpm --filter @contexta/backend dev",
    "dev:dashboard": "pnpm --filter @contexta/dashboard dev",
    "dev:website": "pnpm --filter @contexta/website dev",
    "start": "pnpm run dev:bot & pnpm run dev:backend",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:bot": "pnpm --filter @contexta/bot test",
    "test:dashboard": "pnpm --filter @contexta/dashboard test",
    "db:generate": "pnpm --filter @contexta/db generate",
    "db:migrate": "pnpm --filter @contexta/db migrate"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
